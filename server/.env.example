# ==============================================================================
# CONFIGURAÇÕES DE VARIÁVEIS DE AMBIENTE (API JOGO DE FIIs)
# 
# INSTRUÇÕES PARA O GRUPO:
# 1. Faça uma cópia deste arquivo e renomeie a cópia para ".env"
#    (O arquivo .env será ignorado pelo git para não vazar nossas senhas)
# 2. Se você estiver rodando o banco localmente (via MySQL Workbench local),
#    basta manter o DB_HOST como localhost e garantir que criou o usuário conforme
#    nosso script_jogo_financeiro.sql.
# 3. Se estiver apontando para um banco remoto (AWS, PlanetScale, etc.),
#    edite a variável DB_HOST e suas credenciais.
# 4. Certifique-se de executar "npm install" na pasta "server/" e depois "node index.js".
# ==============================================================================

# Conexão com o Banco de Dados MySQL
DB_HOST=localhost
DB_USER=usuario_tcc
DB_PASSWORD=senha_grupo_123
DB_NAME=jogo_financeiro

# Segurança da Aplicação / Auth
API_KEY=tcc_grupo_7

# Porta do Servidor Node (Opcional, padrão é 3000)
PORT=3000
